generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  SCHEDULED
  CANCELLED
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  timezone          String             @default("Asia/Kolkata")
  eventTypes        EventType[]
  availabilityRules AvailabilityRule[]
  hostedBookings    Booking[]          @relation("HostedBookings")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@map("users")
}

model EventType {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  name            String
  slug            String    @unique
  description     String?
  durationMinutes Int       @map("duration_minutes")
  isActive        Boolean   @default(true) @map("is_active")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("event_types")
}

model AvailabilityRule {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, dayOfWeek])
  @@index([userId, dayOfWeek])
  @@map("availability_rules")
}

model Booking {
  id           String        @id @default(cuid())
  eventTypeId  String        @map("event_type_id")
  hostUserId   String        @map("host_user_id")
  inviteeName  String        @map("invitee_name")
  inviteeEmail String        @map("invitee_email")
  startTimeUtc DateTime      @map("start_time_utc")
  endTimeUtc   DateTime      @map("end_time_utc")
  status       BookingStatus @default(SCHEDULED)
  cancelledAt  DateTime?     @map("cancelled_at")
  eventType    EventType     @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  hostUser     User          @relation("HostedBookings", fields: [hostUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([eventTypeId, startTimeUtc, status])
  @@index([hostUserId, startTimeUtc, status])
  @@map("bookings")
}
